{
  "name": "@readium/playground",
  "version": "1.1.4",
  "description": "Play with Readium technologies in this reference deployment of Thorium Web",
  "keywords": [
    "readium",
    "epub",
    "demo",
    "readium web toolkit",
    "web reader"
  ],
  "license": "BSD-3-Clause",
  "author": {
    "name": "Readium",
    "url": "https://readium.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/readium/playground.git"
  },
  "bugs": {
    "url": "https://github.com/readium/playground/issues"
  },
  "private": true,
  "scripts": {
    "dev": "pnpm copy-assets && next dev",
    "build": "pnpm copy-assets && next build",
    "start": "next start",
    "lint": "eslint .",
    "deploy": "npx @cloudflare/next-on-pages && npx wrangler pages deploy",
    "locales": "cpx \"node_modules/@edrlab/thorium-web/dist/locales/**/*\" public/locales/ && cpx \"src/resources/locales/**/*\" public/locales/",
    "fonts": "cpx \"node_modules/@edrlab/thorium-web/dist/fonts/**/*\" public/fonts/",
    "copy-assets": "pnpm locales && pnpm fonts"
  },
  "dependencies": {
    "@edrlab/thorium-web": "^1.1.4",
    "@readium/css": "2.0.0-beta.24",
    "@readium/navigator": "^2.2.9",
    "@readium/navigator-html-injectables": "^2.2.5",
    "@readium/shared": "^2.1.5",
    "@reduxjs/toolkit": "^2.11.2",
    "classnames": "^2.5.1",
    "i18next": "^25.8.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "motion": "^12.34.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-aria": "^3.46.0",
    "react-aria-components": "^1.15.1",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-modal-sheet": "^5.2.1",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^3.0.6",
    "react-stately": "^3.44.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@svgr/webpack": "^8.1.0",
    "@types/css-modules": "^1.0.5",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "cpx2": "^8.0.0",
    "esbuild-plugin-svgr": "^3.1.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "typescript": "^5.9.3"
  }
}
